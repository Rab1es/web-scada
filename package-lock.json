{
  "name": "web-scada",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "web-scada",
      "workspaces": [
        "client/*",
        "server/*",
        "packages/*"
      ]
    },
    "node_modules/@scada/shared-types": {
      "resolved": "packages/shared-types",
      "link": true
    },
    "packages/shared-types": {
      "name": "@scada/shared-types",
      "version": "1.0.0"
    }
  }
}
